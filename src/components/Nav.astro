---
import type { Content, Lang } from '../i18n/types';
import { getAlternateHref } from '../i18n/ui';
import SocialLinks from './SocialLinks.astro';

interface Props {
  lang: Lang;
  content: Content;
}

const { lang, content } = Astro.props;
const nav = content.nav;
const otherLang: Lang = lang === 'es' ? 'en' : 'es';
const otherHref = getAlternateHref(Astro.url, otherLang);

const links = [
  { href: '#about', label: nav.about },
  { href: '#experience', label: nav.experience },
  { href: '#skills', label: nav.skills },
  { href: '#projects', label: nav.projects },
  { href: '#education', label: nav.education },
  { href: '#contact', label: nav.contact },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-zinc-950/70 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4 sm:px-8"
  >
    <a
      href={lang === 'es' ? '/' : '/en'}
      class="text-sm font-bold tracking-tight text-zinc-100 transition hover:text-accent"
    >
      EM<span class="text-accent">.</span>
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-zinc-400 transition-colors hover:text-zinc-100"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <SocialLinks class="hidden sm:flex" size={16} />
      <a
        href={otherHref}
        class="rounded-full border border-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-zinc-300 transition hover:border-accent hover:text-accent"
        aria-label={`Switch language to ${otherLang}`}
      >
        {otherLang}
      </a>
    </div>
  </nav>
</header>
