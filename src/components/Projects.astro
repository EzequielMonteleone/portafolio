---
import type { Content } from '../i18n/types';

interface Props {
  content: Content;
}

const { content } = Astro.props;
const { projects } = content;
---

<section
  id="projects"
  class="mx-auto max-w-5xl scroll-mt-24 px-5 py-20 sm:px-8"
>
  <h2 class="reveal mb-12 flex items-center gap-3 text-sm font-semibold uppercase tracking-widest text-accent">
    <span class="h-px w-8 bg-accent"></span>
    {projects.title}
  </h2>

  <div class="grid gap-5 sm:grid-cols-2">
    {
      projects.items.map((project, i) => {
        const Tag = project.url ? 'a' : 'div';
        return (
          <Tag
            href={project.url}
            target={project.url ? '_blank' : undefined}
            rel={project.url ? 'noopener noreferrer' : undefined}
            class="reveal group flex flex-col rounded-2xl border border-white/10 bg-white/[0.02] p-6 transition hover:border-accent/50 hover:bg-white/[0.04]"
            style={`animation-delay: ${Math.min(i, 4) * 80}ms`}
          >
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-lg font-semibold text-zinc-100">
                {project.name}
              </h3>
              {project.url && (
                <span class="text-zinc-500 transition group-hover:text-accent">
                  &#8599;
                </span>
              )}
            </div>
            <p class="mt-1 text-xs font-medium uppercase tracking-wider text-accent">
              {project.role}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-zinc-400">
              {project.description}
            </p>
          </Tag>
        );
      })
    }
  </div>
</section>
