---
import type { Content } from '../i18n/types';

interface Props {
  content: Content;
}

const { content } = Astro.props;
const { skills } = content;
---

<section id="skills" class="mx-auto max-w-5xl scroll-mt-24 px-5 py-20 sm:px-8">
  <h2 class="reveal mb-12 flex items-center gap-3 text-sm font-semibold uppercase tracking-widest text-accent">
    <span class="h-px w-8 bg-accent"></span>
    {skills.title}
  </h2>

  <div class="grid gap-8 md:grid-cols-3">
    {
      skills.groups.map((group, i) => (
        <div
          class="reveal rounded-2xl border border-white/10 bg-white/[0.02] p-6"
          style={`animation-delay: ${i * 100}ms`}
        >
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-zinc-300">
            {group.label}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-lg border border-white/5 bg-white/5 px-3 py-1.5 text-xs font-medium text-zinc-300">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
