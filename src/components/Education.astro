---
import type { Content } from '../i18n/types';

interface Props {
  content: Content;
}

const { content } = Astro.props;
const { education } = content;
---

<section
  id="education"
  class="mx-auto max-w-5xl scroll-mt-24 px-5 py-20 sm:px-8"
>
  <h2 class="reveal mb-12 flex items-center gap-3 text-sm font-semibold uppercase tracking-widest text-accent">
    <span class="h-px w-8 bg-accent"></span>
    {education.title}
  </h2>

  <div class="grid gap-5 sm:grid-cols-2">
    {
      education.items.map((item, i) => (
        <div
          class="reveal rounded-2xl border border-white/10 bg-white/[0.02] p-6"
          style={`animation-delay: ${i * 100}ms`}
        >
          <h3 class="text-lg font-semibold text-zinc-100">{item.title}</h3>
          <p class="mt-1 text-sm text-zinc-400">{item.institution}</p>
          <p class="mt-3 text-xs font-medium uppercase tracking-wider text-zinc-500">
            {item.period}
          </p>
        </div>
      ))
    }
  </div>
</section>
