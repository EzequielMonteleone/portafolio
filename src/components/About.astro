---
import type { Content } from '../i18n/types';

interface Props {
  content: Content;
}

const { content } = Astro.props;
const { about } = content;
---

<section id="about" class="mx-auto max-w-5xl scroll-mt-24 px-5 py-20 sm:px-8">
  <h2 class="reveal mb-8 flex items-center gap-3 text-sm font-semibold uppercase tracking-widest text-accent">
    <span class="h-px w-8 bg-accent"></span>
    {about.title}
  </h2>
  <div class="space-y-5">
    {
      about.paragraphs.map((p, i) => (
        <p
          class="reveal max-w-3xl text-lg leading-relaxed text-zinc-300"
          style={`animation-delay: ${i * 100}ms`}
        >
          {p}
        </p>
      ))
    }
  </div>
</section>
